# LLM failover (chatbot del dashboard) — al menos una key requerida
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-27b-it:free

OPENCODE_API_KEY=
OPENCODE_MODEL=deepseek-v4-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Opcional — Regenerar reportes
MIROFISH_WEBHOOK_URL=
MIROFISH_WEBHOOK_SECRET=

# DashWeb Core — proxy servidor read-only; nunca exponer en cliente
DASHWEB_API_URL=https://dashweb-backend-dev.up.railway.app/api/v1
DASHWEB_SERVICE_TOKEN=

# GA4 Data API
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Metricool
METRICOOL_API_TOKEN=
METRICOOL_BRAND_ID=

# Auth roles (Sprint 4) — sin AUTH_SECRET el dashboard queda abierto (ops)
AUTH_SECRET=
AUTH_OPS_PASSWORD=
AUTH_PITCH_PASSWORD=
AUTH_CLIENT_PASSWORD=

# Google Calendar LIVE — cuenta rraliadosteam@gmail.com
# En Vercel: Project → Settings → Environment Variables (Production)
# Sin estas tres → /api/calendar responde DEMO honesto (badge Mock, no datos inventados de Google)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
# Opcional (default: rraliadosteam@gmail.com)
GOOGLE_CALENDAR_ID=rraliadosteam@gmail.com
